# Development environment template — copy to .env
# For production, see .env.production instead

# Local SQLite database (auto-created)
# For production Supabase, use: postgresql://postgres:PASSWORD@db.PROJECT_ID.supabase.co:5432/postgres?sslmode=require
DATABASE_URL=sqlite:///./crowdflow.db

# JWT secret (minimum 32 random characters)
# Generate: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=dev-secret-not-for-production-change-me

# Frontend API URL
VITE_BACKEND_URL=http://localhost:8000

# Allow falling back to SQLite if Supabase is unreachable (dev only)
# Production: set to false to fail fast
ALLOW_SQLITE_FALLBACK=true

# Optional: Supabase credentials (not needed for local SQLite)
# SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
# SUPABASE_ANON_KEY=eyJ...
